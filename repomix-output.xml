                  description: Event provider (e.g. github).
                  minLength: 1
                event:
                  type: string
                  description: Normalized event name (e.g. push, pull_request).
                  minLength: 1
                actions:
                  type: array
                  description: Optional event action filter.
                  items:
                    type: string
                branches:
                  type: array
                  description: Optional source/ref branch filter (supports globs).
                  items:
                    type: string
                baseBranches:
                  type: array
                  description: Optional PR base branch filter (supports globs).
                  items:
                    type: string
                tags:
                  type: array
                  description: Optional tag filter (supports globs).
                  items:
                    type: string
              additionalProperties: false
            plan:
              type: object
              properties:
                scope:
                  type: string
                  description: Plan scope when this trigger fires.
                  enum:
                    - full
                    - changed
                base:
                  type: string
                  description: Dot-path into the raw event payload for the base revision.
                head:
                  type: string
                  description: Dot-path into the raw event payload for the head revision.
              additionalProperties: false
    additionalProperties: false
  execution:
    type: object
    description: Optional execution-layer configuration (remote state, etc.)
    properties:
      state:
        type: object
        description: Controls where execution state is stored.
        properties:
          mode:
            type: string
            description: State storage mode. "local" uses the filesystem (default); "remote" uses orun-backend.
            enum:
              - local
              - remote
          backendUrl:
            type: string
            description: URL of the orun-backend instance (required when mode is remote).
            format: uri
        additionalProperties: false
    additionalProperties: false
  components:
    type: array
    items:
      type: object
      required:
        - name
        - type
      properties:
        name:
          type: string
          minLength: 1
          maxLength: 63
        type:
          type: string
          minLength: 1
        domain:
          type: string
        enabled:
          type: boolean
          default: true
        path:
          type: string
          description: Working directory path for component execution (highest priority in override hierarchy, supports template variables)
        subscribe:
          type: object
          properties:
            environments:
              type: array
              items:
                type: string
        compositionRef:
          type: object
          properties:
            source:
              type: string
            name:
              type: string
        parameters:
          type: object
          additionalProperties: true
        overrides:
          type: object
          properties:
            steps:
              type: array
              items:
                type: object
                required:
