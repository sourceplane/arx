                  - run
                properties:
                  name:
                    type: string
                    minLength: 1
                  phase:
                    type: string
                    enum:
                      - pre
                      - main
                      - post
                    default: main
                  order:
                    type: integer
                    minimum: 0
                  run:
                    type: string
                    minLength: 1
                  timeout:
                    type: string
                    pattern: ^[0-9]+(m|h|s)$
                  retry:
                    type: integer
                    minimum: 0
                    maximum: 10
                  onFailure:
                    type: string
                    enum:
                      - stop
                      - continue
        labels:
          type: object
          additionalProperties:
            type: string
        dependsOn:
          type: array
          items:
            type: object
            required:
              - component
            properties:
              component:
                type: string
              environment:
                type: string
              scope:
                type: string
                enum:
                  - same-environment
