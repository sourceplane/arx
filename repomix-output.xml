<file path="assets/config/compositions/helm/job.yaml">
apiVersion: sourceplane.io/v1
kind: JobRegistry
metadata:
  name: helm-jobs
  description: Helm deployment jobs
jobs:
  - name: deploy
    description: Deploy using Helm
    runsOn: ubuntu-22.04
    timeout: 15m
    retries: 2
    labels:
      scope: deployment
    steps:
      - name: add-repository
        run: helm repo add mycompany oci://mycompany.azurecr.io/helm/charts
        retry: 3
      - name: update-repo
        run: helm repo update
        retry: 2
      - name: deploy
        run: helm upgrade --install {{.orun.component.name}} {{.parameters.chart}} --namespace {{.parameters.namespacePrefix}}{{.orun.component.name}} --create-namespace --wait=true --timeout={{.parameters.timeout}}
        timeout: 15m
        onFailure: stop
      - name: verify
        run: kubectl get deployment -n {{.parameters.namespacePrefix}}{{.orun.component.name}} {{.orun.component.name}}
        onFailure: continue
    inputs:
      pullPolicy: IfNotPresent
      imagePullSecrets: []

  - name: rollback
    description: Rollback Helm release to previous version
    runsOn: ubuntu-22.04
    timeout: 10m
    retries: 1
    labels:
      scope: recovery
    steps:
      - name: get-revision
        run: helm history {{.orun.component.name}} -n {{.parameters.namespacePrefix}}{{.orun.component.name}} | head -2
        onFailure: stop
      - name: rollback
        run: helm rollback {{.orun.component.name}} -n {{.parameters.namespacePrefix}}{{.orun.component.name}}
        timeout: 10m
        onFailure: stop
      - name: verify-rollback
        run: kubectl rollout status deployment/{{.orun.component.name}} -n {{.parameters.namespacePrefix}}{{.orun.component.name}}
        onFailure: continue
    inputs:
      pullPolicy: IfNotPresent

  - name: diff
    description: Show differences between deployed and intended Helm release
    runsOn: ubuntu-22.04
    timeout: 5m
    retries: 0
    labels:
      scope: analysis
    steps:
      - name: add-repository
        run: helm repo add mycompany oci://mycompany.azurecr.io/helm/charts
        retry: 3
      - name: diff
        run: helm diff release {{.orun.component.name}} {{.parameters.chart}} --namespace {{.parameters.namespacePrefix}}{{.orun.component.name}} || true
        onFailure: continue
    inputs:
      pullPolicy: IfNotPresent
</file>

