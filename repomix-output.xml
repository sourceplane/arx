        type: array
        description: Optional directories to recursively scan for component.yaml files relative to the intent file.
        items:
          type: string
  compositions:
    type: object
    properties:
      sources:
        type: array
        items:
          type: object
          required:
            - name
            - kind
          properties:
            name:
              type: string
              minLength: 1
            kind:
              type: string
              enum:
                - dir
                - archive
                - oci
            path:
              type: string
            ref:
              type: string
            digest:
              type: string
            pullPolicy:
              type: string
            metadata:
              type: object
              additionalProperties:
                type: string
      resolution:
        type: object
        properties:
          precedence:
            type: array
            items:
              type: string
          bindings:
            type: object
            additionalProperties:
              type: string
  groups:
    type: object
    additionalProperties:
      type: object
      properties:
        policies:
          type: object
          additionalProperties: true
        parameterDefaults:
          type: object
          description: Default parameters for components in this group, keyed by composition type or "*" for all types
          additionalProperties:
            type: object
            additionalProperties: true
  environments:
    type: object
    additionalProperties:
      type: object
      properties:
        activation:
          type: object
          properties:
            triggerRefs:
              type: array
              description: Names of trigger bindings that activate this environment.
              items:
                type: string
                minLength: 1
          additionalProperties: false
        promotion:
          type: object
          description: Environment promotion dependencies for ordering/gating between environments.
          properties:
            dependsOn:
              type: array
              items:
                type: object
                required:
                  - environment
                properties:
                  environment:
                    type: string
                    minLength: 1
                    description: Name of the environment that must succeed before this one.
                  strategy:
                    type: string
                    enum:
                      - same-component
                      - environment-barrier
                    default: same-component
                    description: How to map dependencies. same-component links matching components; environment-barrier waits for all jobs.
                  condition:
                    type: string
                    enum:
                      - success
                    default: success
                  satisfy:
                    type: string
                    enum:
                      - same-plan
                      - previous-success
                      - same-plan-or-previous-success
                    default: same-plan-or-previous-success
                    description: Whether to use in-plan DAG edges, prior evidence, or both.
                  match:
                    type: object
                    properties:
                      revision:
                        type: string
