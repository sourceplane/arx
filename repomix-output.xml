    "resolverVersion": 1,
    "stackSources": [
      "ghcr.io/sourceplane/stack-tectonic:0.12.0"
    ]
  },
  "catalogHash": "sha256:c8e91d2a...",
  "summary": {
    "components": 42,
    "systems": 6,
    "apis": 12,
    "resources": 18,
    "owners": 8,
    "domains": 4
  },
