const (
	APIVersion = "orun.io/v1alpha1"
	KindName   = "PlanRevision"

	// idPrefixRevision is concatenated with the underlying ULID to form a
	// PlanRevision.RevisionID. Mirrors triggerctx's "trg_" convention.
