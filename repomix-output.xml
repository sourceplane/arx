<file path="examples/compositions/compositions/cloudflare-pages-turbo/jobs/cloudflare-pages-turbo-verify-deploy.yaml">
apiVersion: sourceplane.io/v1alpha1
kind: JobTemplate
metadata:
  name: cloudflare-pages-turbo-verify-deploy
spec:
  description: Verify and deploy Cloudflare Pages apps built with Turbo
  runsOn: ubuntu-22.04
  timeout: 30m
  retries: 0

  labels:
    scope: delivery

  capabilities:
    - cloudflare-pages-turbo.setup-node
    - cloudflare-pages-turbo.setup-pnpm
    - cloudflare-pages-turbo.install
    - cloudflare-pages-turbo.pre-build
    - cloudflare-pages-turbo.verify-structure
    - cloudflare-pages-turbo.build
    - cloudflare-pages-turbo.verify-output
    - cloudflare-pages-turbo.provision
    - cloudflare-pages-turbo.deploy

  steps:
    - id: setup-node
      name: setup-node
      capability: cloudflare-pages-turbo.setup-node
      use: actions/setup-node@v4
      with:
        node-version: "{{.parameters.nodeVersion}}"

    - id: setup-pnpm
      name: setup-pnpm
      capability: cloudflare-pages-turbo.setup-pnpm
      use: pnpm/action-setup@v4
      with:
        version: "{{.parameters.pnpmVersion}}"

    - id: install-workspace-dependencies
      name: install-workspace-dependencies
      capability: cloudflare-pages-turbo.install
      run: pnpm install --no-frozen-lockfile
      onFailure: stop

    - id: pre-build
      name: pre-build
      capability: cloudflare-pages-turbo.pre-build
      shell: bash
      run: |
        {{if .preBuildCommand}}
        {{.parameters.preBuildCommand}}
        {{else}}
        echo "Skipping pre-build."
        {{end}}
      onFailure: stop

    - id: verify-pages-app-structure
      name: verify-pages-app-structure
      capability: cloudflare-pages-turbo.verify-structure
      run: test -f package.json
      onFailure: stop

    - id: build-pages-app
      name: build-pages-app
      capability: cloudflare-pages-turbo.build
      run: "{{if .buildCommand}}{{.parameters.buildCommand}}{{else}}pnpm exec turbo run build --filter=./{{end}}"
      onFailure: stop

    - id: verify-build-output
      name: verify-build-output
      capability: cloudflare-pages-turbo.verify-output
      shell: bash
      run: |
        test -d "{{.parameters.outputDir}}"
        find "{{.parameters.outputDir}}" -maxdepth 2 -type f | head -n 20
      onFailure: stop

    - id: ensure-pages-project
      name: ensure-pages-project
      capability: cloudflare-pages-turbo.provision
      shell: bash
      run: |
        if [ "{{.orun.environment.name}}" != "production" ] || [ "${GITHUB_REF:-}" != "refs/heads/{{.parameters.productionBranch}}" ]; then
          echo "Skipping Cloudflare Pages project reconciliation for {{.orun.component.name}} in {{.orun.environment.name}} on ${GITHUB_REF:-local}."
          exit 0
        fi

        : "${CLOUDFLARE_ACCOUNT_ID:?CLOUDFLARE_ACCOUNT_ID is required for deployment}"
        : "${CLOUDFLARE_API_TOKEN:?CLOUDFLARE_API_TOKEN is required for deployment}"

        api_root="https://api.cloudflare.com/client/v4/accounts/${CLOUDFLARE_ACCOUNT_ID}/pages/projects"
        response_file="${RUNNER_TEMP:-/tmp}/cloudflare-pages-project.json"
        status="$(curl -sS -o "${response_file}" -w "%{http_code}" \
          -H "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
          -H "Content-Type: application/json" \
          "${api_root}/{{.parameters.projectName}}")"

        if [ "${status}" = "200" ]; then
          echo "Pages project {{.parameters.projectName}} already exists."
        elif [ "${status}" = "404" ]; then
          curl -sS --fail -X POST \
            -H "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
            -H "Content-Type: application/json" \
            --data '{"name":"{{.parameters.projectName}}","production_branch":"{{.parameters.productionBranch}}"}' \
            "${api_root}" >/dev/null
          echo "Created Pages project {{.parameters.projectName}}."
        else
          cat "${response_file}"
          exit 1
        fi

        curl -sS --fail -X PATCH \
          -H "Authorization: Bearer ${CLOUDFLARE_API_TOKEN}" \
          -H "Content-Type: application/json" \
          --data '{"production_branch":"{{.parameters.productionBranch}}"}' \
          "${api_root}/{{.parameters.projectName}}" >/dev/null
      onFailure: stop

    - id: deploy-pages-artifact
      name: deploy-pages-artifact
      capability: cloudflare-pages-turbo.deploy
      shell: bash
      run: |
        if [ "{{.orun.environment.name}}" != "production" ] || [ "${GITHUB_REF:-}" != "refs/heads/{{.parameters.productionBranch}}" ]; then
          echo "Skipping Cloudflare Pages deploy for {{.orun.component.name}} in {{.orun.environment.name}} on ${GITHUB_REF:-local}."
          exit 0
        fi

        : "${CLOUDFLARE_ACCOUNT_ID:?CLOUDFLARE_ACCOUNT_ID is required for deployment}"
        : "${CLOUDFLARE_API_TOKEN:?CLOUDFLARE_API_TOKEN is required for deployment}"

        pnpm exec wrangler pages deploy "{{.parameters.outputDir}}" \
          --project-name "{{.parameters.projectName}}" \
          --branch "{{.parameters.productionBranch}}"
      onFailure: stop
</file>

