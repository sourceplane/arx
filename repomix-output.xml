<file path="examples/compositions/compositions/cloudflare-pages-terraform/composition.yaml">
apiVersion: sourceplane.io/v1alpha1
kind: Composition
metadata:
  name: cloudflare-pages-terraform
spec:
  type: cloudflare-pages-terraform
  description: Cloudflare Pages deployment managed with Terraform

  schemaRef:
    name: cloudflare-pages-terraform-component

  defaultJob: verify-reconcile
