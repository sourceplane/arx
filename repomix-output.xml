                          - source
                        description: How to match prior success evidence (source = same commit).
                    additionalProperties: false
          additionalProperties: false
        selectors:
          type: object
          properties:
            components:
              type: array
              items:
                type: string
            domains:
              type: array
              items:
                type: string
        parameterDefaults:
          type: object
          description: Default parameters for components in this environment, keyed by composition type or "*" for all types
          additionalProperties:
            type: object
            additionalProperties: true
        policies:
          type: object
          additionalProperties: true
  automation:
    type: object
    description: Trigger binding declarations for CI/event-driven planning.
    properties:
      triggerBindings:
