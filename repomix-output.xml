<file path="cleanup/ci.yml">
name: CI

on:
  pull_request:
  push:
    branches:
      - main

permissions:
  contents: read

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
          cache: true

      - name: Run Go tests
        run: go test ./...

      - name: Run GitHub Actions compatibility tests
        run: go test ./internal/gha -run 'Test(ParseKVFileSupportsHeredocAndBOM|ProcessWorkflowCommandsParsesLegacyCommands|EngineRunStepLocalCompositeActionPropagatesOutputsAndEnv)$'

      - name: Validate provider package build
        uses: sourceplane/kiox-release-action@v2.0.1
        with:
          manifest: provider.yaml
          main: ./cmd/orun
          output: oci
          dist: dist
          tag: ci
          kiox-version: v0.4.3

      - name: Smoke test provider with kiox-action
        uses: sourceplane/kiox-action@v2.1.2
        with:
          version: v0.4.3
          providers: |
            ${{ github.workspace }}/oci as orun
          run: |
            kiox --workspace "$KIOX_WORKSPACE_ROOT" provider list
            orun validate --intent "$GITHUB_WORKSPACE/examples/intent.yaml"
            orun compositions lock --intent "$GITHUB_WORKSPACE/examples/intent.yaml"
            orun plan \
              --intent "$GITHUB_WORKSPACE/examples/intent.yaml" \
              --output "$RUNNER_TEMP/orun-plan.json"
            test -s "$RUNNER_TEMP/orun-plan.json"
            orun plan \
              --intent "$GITHUB_WORKSPACE/examples/intent.yaml" \
              --component network-foundation \
              --env development \
              --output "$RUNNER_TEMP/orun-example-smoke-plan.json"
            test -s "$RUNNER_TEMP/orun-example-smoke-plan.json"
            orun run \
              --plan "$RUNNER_TEMP/orun-example-smoke-plan.json" \
              --workdir "$GITHUB_WORKSPACE/examples" \
              --gha

      - name: Verify stack OCI packaging
        uses: sourceplane/kiox-action@v2.1.2
        with:
          version: v0.4.3
          providers: |
            ${{ github.workspace }}/oci as orun
          run: |
            # Verify stack.yaml is the canonical manifest.
            test -f "$GITHUB_WORKSPACE/examples/compositions/stack.yaml"

            # Pack the stack and verify the archive is non-empty.
            orun pack \
              --root "$GITHUB_WORKSPACE/examples/compositions" \
              --output "$RUNNER_TEMP/example-platform-compositions.tgz"
            test -s "$RUNNER_TEMP/example-platform-compositions.tgz"

            # Dry-run publish to verify OCI ref resolution from stack.yaml registry block.
            orun publish \
              --root "$GITHUB_WORKSPACE/examples/compositions" \
              --dry-run

      - name: Smoke test --changed flag
        uses: sourceplane/kiox-action@v2.1.2
        with:
          version: v0.4.3
          providers: |
            ${{ github.workspace }}/oci as orun
          run: |
            # Single leaf component changed
            orun component --changed --files apps/web-console/src/app.js \
              --intent "$GITHUB_WORKSPACE/examples/intent.yaml"

            # Infra change triggers dependency chain
            orun plan --changed --files infra/infra-1/main.tf \
              --intent "$GITHUB_WORKSPACE/examples/intent.yaml" \
              --output "$RUNNER_TEMP/orun-changed-infra.json"
            test -s "$RUNNER_TEMP/orun-changed-infra.json"

            # Intent change = all components
            orun plan --changed --files intent.yaml \
              --intent "$GITHUB_WORKSPACE/examples/intent.yaml" \
              --output "$RUNNER_TEMP/orun-changed-intent.json"
            test -s "$RUNNER_TEMP/orun-changed-intent.json"

            # No matching files = no crash, empty output
            orun component --changed --files README.md \
              --intent "$GITHUB_WORKSPACE/examples/intent.yaml"

            # Flag conflicts are rejected
            ! orun component --changed --files foo.txt --uncommitted \
              --intent "$GITHUB_WORKSPACE/examples/intent.yaml" 2>/dev/null

            # CI auto-detection with --explain
            orun component --changed --explain \
              --intent "$GITHUB_WORKSPACE/examples/intent.yaml"
</file>

<file path="cleanup/remote-state-conformance.yml">
# remote-state-conformance.yml
#
# Smoke-tests the remote-state client integration against the live orun-backend.
#
# Gating:
#   - Always available via workflow_dispatch (manual trigger)
#   - On push/PR: only runs when vars.REMOTE_STATE_TESTS == 'true'
#     (set in repo Settings → Variables → Actions)
#
# Authentication:
#   GitHub Actions OIDC (id-token: write). The live backend verifies
#   GitHub Actions OIDC JWTs — no static ORUN_TOKEN is needed.
#
# Required repository configuration:
#   vars.ORUN_BACKEND_URL    - URL of the live orun-backend
#   vars.REMOTE_STATE_TESTS  - Set to 'true' to enable on push/PR

name: remote-state-conformance

on:
  workflow_dispatch:
  push:
    branches: [main]
    paths:
      - 'internal/remotestate/**'
      - 'internal/statebackend/**'
      - 'cmd/orun/command_run.go'
      - 'cmd/orun/command_status.go'
      - 'cmd/orun/command_logs.go'
      - 'examples/remote-state-matrix/**'
      - '.github/workflows/remote-state-conformance.yml'
  pull_request:
    paths:
      - 'internal/remotestate/**'
      - 'internal/statebackend/**'
      - 'cmd/orun/command_run.go'
      - 'cmd/orun/command_status.go'
      - 'cmd/orun/command_logs.go'
      - 'examples/remote-state-matrix/**'
      - '.github/workflows/remote-state-conformance.yml'

permissions:
  contents: read
  id-token: write

jobs:
  plan:
    name: Compile plan
    if: github.event_name == 'workflow_dispatch' || vars.REMOTE_STATE_TESTS == 'true'
    runs-on: ubuntu-latest
    outputs:
      plan_id: ${{ steps.plan.outputs.plan_id }}
      run_id: ${{ steps.plan.outputs.run_id }}
      jobs: ${{ steps.matrix.outputs.jobs }}
      first_job: ${{ steps.matrix.outputs.first_job }}
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod

      - name: Install orun
        run: go install ./cmd/orun

      - name: Compile plan
        id: plan
        working-directory: examples/remote-state-matrix
        run: |
          orun plan --name remote-state-e2e --all
          plan_id="$(orun get plans -o json | jq -r '.[] | select(.Name == "remote-state-e2e") | .Checksum')"
          run_id="gha-${GITHUB_RUN_ID}-${GITHUB_RUN_ATTEMPT}-${plan_id}"
          echo "plan_id=${plan_id}" >> "${GITHUB_OUTPUT}"
          echo "run_id=${run_id}" >> "${GITHUB_OUTPUT}"

      - name: Build job matrix
        id: matrix
        working-directory: examples/remote-state-matrix
        run: |
          jobs="$(orun get jobs --plan '${{ steps.plan.outputs.plan_id }}' --all -o json \
            | jq -c '[.[] | {job: .id, env: .environment, component: .component}]')"
          first_job="$(printf '%s' "${jobs}" | jq -r '.[0].job')"
          # Append a duplicate to prove idempotent claim behavior.
          jobs="$(printf '%s' "${jobs}" | jq -c --arg job "${first_job}" '. + [{job: $job, env: "duplicate", component: "duplicate"}]')"
          echo "jobs=${jobs}" >> "${GITHUB_OUTPUT}"
          echo "first_job=${first_job}" >> "${GITHUB_OUTPUT}"

      - name: Upload compiled plan
        uses: actions/upload-artifact@v4
        with:
          name: orun-remote-state-plan
          path: examples/remote-state-matrix/.orun/plans/
          if-no-files-found: error

  run-jobs:
    name: "Job: ${{ matrix.job }}"
    needs: plan
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        include: ${{ fromJson(needs.plan.outputs.jobs) }}
    env:
      ORUN_BACKEND_URL: ${{ vars.ORUN_BACKEND_URL }}
      ORUN_REMOTE_STATE: "true"
      ORUN_EXEC_ID: ${{ needs.plan.outputs.run_id }}
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod

      - name: Install orun
        run: go install ./cmd/orun

      - name: Download compiled plan
        uses: actions/download-artifact@v4
        with:
          name: orun-remote-state-plan
          path: examples/remote-state-matrix/.orun/plans/

      - name: Run job via remote state
        working-directory: examples/remote-state-matrix
        run: |
          orun run '${{ needs.plan.outputs.plan_id }}' \
            --job '${{ matrix.job }}' \
            --remote-state \
            --backend-url "${ORUN_BACKEND_URL}" \
            --gha \
            --verbose

  run-env-fanout:
    name: "Env: ${{ matrix.env_name }}"
    needs: plan
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        env_name: [dev, stage]
    env:
      ORUN_BACKEND_URL: ${{ vars.ORUN_BACKEND_URL }}
      ORUN_REMOTE_STATE: "true"
      ORUN_EXEC_ID: env-${{ needs.plan.outputs.run_id }}
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod

      - name: Install orun
        run: go install ./cmd/orun

      - name: Download compiled plan
        uses: actions/download-artifact@v4
        with:
          name: orun-remote-state-plan
          path: examples/remote-state-matrix/.orun/plans/

      - name: Run environment slice
        working-directory: examples/remote-state-matrix
        run: |
          orun run '${{ needs.plan.outputs.plan_id }}' \
            --env '${{ matrix.env_name }}' \
            --remote-state \
            --backend-url "${ORUN_BACKEND_URL}" \
            --gha

  verify:
    name: Verify remote state
    needs: [plan, run-jobs, run-env-fanout]
    if: always()
    runs-on: ubuntu-latest
    env:
      ORUN_BACKEND_URL: ${{ vars.ORUN_BACKEND_URL }}
      ORUN_REMOTE_STATE: "true"
      ORUN_EXEC_ID: ${{ needs.plan.outputs.run_id }}
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod

      - name: Install orun
        run: go install ./cmd/orun

      - name: Download compiled plan
        uses: actions/download-artifact@v4
        with:
          name: orun-remote-state-plan
          path: examples/remote-state-matrix/.orun/plans/

      - name: Check remote status
        working-directory: examples/remote-state-matrix
        run: |
          echo "=== Remote State Status ==="
          orun status \
            --remote-state \
            --backend-url "${ORUN_BACKEND_URL}" \
            --exec-id "${ORUN_EXEC_ID}" \
            --json

      - name: Check remote logs
        working-directory: examples/remote-state-matrix
        run: |
          echo "=== Remote Logs for ${{ needs.plan.outputs.first_job }} ==="
          orun logs \
            --remote-state \
            --backend-url "${ORUN_BACKEND_URL}" \
            --exec-id "${ORUN_EXEC_ID}" \
            --job '${{ needs.plan.outputs.first_job }}'

      - name: Assert all jobs succeeded
        working-directory: examples/remote-state-matrix
        run: |
          status_json="$(orun status \
            --remote-state \
            --backend-url "${ORUN_BACKEND_URL}" \
            --exec-id "${ORUN_EXEC_ID}" \
            --json)"
          echo "${status_json}" | jq .

          failed="$(echo "${status_json}" | jq '[.state.jobs | to_entries[] | select(.value.status == "failed")] | length')"
          if [ "${failed}" -gt 0 ]; then
            echo "::error::${failed} job(s) failed in remote state"
            exit 1
          fi

          total="$(echo "${status_json}" | jq '[.state.jobs | to_entries[]] | length')"
          completed="$(echo "${status_json}" | jq '[.state.jobs | to_entries[] | select(.value.status == "completed")] | length')"
          echo "Remote state verification: ${completed}/${total} jobs completed successfully."
</file>

<file path="cleanup/test-changed-pr.yml">
name: Test --changed in PR context

on:
  pull_request:

permissions:
  contents: read

jobs:
  test-changed-pr:
    runs-on: ubuntu-latest

    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - uses: actions/setup-go@v5
        with:
          go-version-file: go.mod
          cache: true

      - name: Build orun
        run: go build -o orun ./cmd/orun

      - name: Test --changed with CI auto-detection
        run: |
          ./orun component --changed \
            --intent examples/intent.yaml

      - name: Test --changed with --explain
        run: |
          ./orun component --changed --explain \
            --intent examples/intent.yaml

      - name: Test --changed with explicit --base override
        run: |
          ./orun component --changed \
            --base "${{ github.event.pull_request.base.ref }}" \
            --intent examples/intent.yaml

      - name: Test plan --changed with CI auto-detection
        run: |
          ./orun plan --changed \
            --intent examples/intent.yaml \
            --output /tmp/pr-changed-plan.json || true
</file>

