        echo "Skipping pre-build."
        {{end}}
      onFailure: stop

    - id: verify-package-structure
      name: verify-package-structure
      capability: turbo-package.verify-structure
      run: test -f package.json
      onFailure: stop

    - id: build-package
      name: build-package
      capability: turbo-package.build
      run: "{{if .buildCommand}}{{.parameters.buildCommand}}{{else}}pnpm exec turbo run build --filter=./{{end}}"
      onFailure: stop

    - id: typecheck-package
      name: typecheck-package
      capability: turbo-package.typecheck
      run: "{{if .typecheckCommand}}{{.parameters.typecheckCommand}}{{else}}pnpm exec turbo run typecheck --filter=./{{end}}"
      onFailure: stop
</file>

